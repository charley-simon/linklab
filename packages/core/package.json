{
  "name": "@linklab/core",
  "version": "0.1.0",
  "type": "module",
  "description": "LinkLab core — semantic navigation graph engine",
  "author": "Charley Simon",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rimraf --glob dist \"src/**/*.js\" \"src/**/*.d.ts\" \"tests/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}