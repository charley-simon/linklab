{
  "name": "@linklabjs/telemetry",
  "version": "0.1.0",
  "type": "module",
  "description": "Observability pipeline for LinkLab — traces, metrics, calibration",
  "author": "Charley Simon",
  "license": "MIT",
  "homepage": "https://github.com/charley-simon/linklab",
  "repository": {
    "type": "git",
    "url": "https://github.com/charley-simon/linklab.git",
    "directory": "packages/telemetry"
  },
  "keywords": ["linklab", "telemetry", "observability", "traces", "metrics", "duckdb", "typescript"],
  "main":  "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build":          "pnpm run clean && tsc -p tsconfig.json",
    "clean":          "rimraf --glob dist",
    "dev":            "tsc --watch",
    "test":           "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.0-r.1",
    "@linklabjs/core":    "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "rimraf":      "^6.1.3",
    "typescript":  "^5.9.3",
    "vitest":      "^2.0.0"
  },
  "engines": { "node": ">=18" }
}