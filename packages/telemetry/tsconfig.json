{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declarationDir": "./dist",
    "baseUrl": "../..",
    "paths": {
      "@linklab/core":   ["packages/core/src"],
      "@linklab/core/*": ["packages/core/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}